<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Tug of WAR-X</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap');

:root {
  --bg: #fff8f0;
  --card: #ffffff;
  --text: #1a1a2e;
  --accent1: #ff6b6b;
  --accent2: #6c63ff;
  --grass: #4ecb71;
  --shadow: rgba(0,0,0,0.12);
  --rope-brown: #8B4513;
  --rope-tan: #D2691E;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  min-height: 100vh;
  color: var(--text);
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse at 15% 15%, #ffe0e044 0%, transparent 55%),
    radial-gradient(ellipse at 85% 85%, #e0e0ff44 0%, transparent 55%),
    radial-gradient(ellipse at 50% 50%, #fff3e044 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

.screen {
  display: none;
  position: relative;
  z-index: 1;
  min-height: 100vh;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px 16px;
}
.screen.active { display: flex; }

/* ===== TYPOGRAPHY ===== */
.title {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(2rem, 7vw, 3rem);
  background: linear-gradient(135deg, var(--accent1), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
  line-height: 1.1;
}

.subtitle {
  font-size: 0.9rem;
  font-weight: 700;
  color: #9ca3af;
  text-align: center;
  margin-top: 4px;
  margin-bottom: 24px;
}

/* ===== CARDS ===== */
.card {
  background: var(--card);
  border-radius: 24px;
  padding: 24px;
  box-shadow: 0 8px 32px var(--shadow);
  width: 100%;
  max-width: 400px;
  border: 2px solid rgba(255,255,255,0.9);
}

/* ===== INPUTS ===== */
.input-group { margin-bottom: 14px; }
.input-group label {
  display: block;
  font-weight: 800;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #9ca3af;
  margin-bottom: 6px;
}

input[type="text"] {
  width: 100%;
  padding: 14px 16px;
  border: 2.5px solid #e5e7eb;
  border-radius: 14px;
  font-family: 'Nunito', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  background: #f9fafb;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
input[type="text"]:focus {
  border-color: var(--accent2);
  box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
  background: white;
}

/* ===== BUTTONS ===== */
.btn {
  width: 100%;
  padding: 16px;
  border: none;
  border-radius: 14px;
  font-family: 'Fredoka One', cursive;
  font-size: 1.15rem;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  letter-spacing: 0.02em;
}
.btn:active { transform: scale(0.97); }

.btn-primary {
  background: linear-gradient(135deg, var(--accent1), var(--accent2));
  color: white;
  box-shadow: 0 4px 16px rgba(108,99,255,0.35);
  margin-top: 8px;
}
.btn-primary:hover { box-shadow: 0 6px 24px rgba(108,99,255,0.45); transform: translateY(-1px); }

.btn-secondary {
  background: linear-gradient(135deg, #f59e0b, #ef4444);
  color: white;
  box-shadow: 0 4px 16px rgba(239,68,68,0.3);
  margin-top: 8px;
}

.btn-small {
  width: auto;
  padding: 10px 20px;
  font-size: 1rem;
  border-radius: 12px;
}

/* ===== LOBBY ===== */
#lobbyScreen { gap: 12px; }

.divider {
  font-weight: 800;
  color: #d1d5db;
  font-size: 0.85rem;
  letter-spacing: 0.1em;
}

/* ===== BREED PICKER ===== */
#pickerScreen { justify-content: flex-start; padding-top: 24px; }

.picker-title {
  font-family: 'Fredoka One', cursive;
  font-size: 1.5rem;
  text-align: center;
  margin-bottom: 4px;
  color: var(--text);
}

.picker-subtitle {
  font-size: 0.85rem;
  color: #9ca3af;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16px;
}

.breed-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  width: 100%;
  max-width: 400px;
  margin-bottom: 16px;
}

.breed-card {
  background: white;
  border: 3px solid #e5e7eb;
  border-radius: 18px;
  padding: 12px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.breed-card:active { transform: scale(0.96); }
.breed-card.selected {
  border-color: var(--accent2);
  box-shadow: 0 0 0 3px rgba(108,99,255,0.2), 0 4px 16px rgba(108,99,255,0.2);
  background: #f5f3ff;
}

.breed-card svg {
  width: 70px;
  height: 70px;
}

.breed-name {
  font-family: 'Fredoka One', cursive;
  font-size: 0.85rem;
  color: var(--text);
  text-align: center;
}

/* ===== WAITING ===== */
.room-code {
  font-family: 'Fredoka One', cursive;
  font-size: 3rem;
  letter-spacing: 0.2em;
  color: var(--accent2);
  text-align: center;
  background: #f5f3ff;
  padding: 16px 28px;
  border-radius: 18px;
  border: 3px dashed var(--accent2);
  margin: 16px 0;
}

.pulse { animation: pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(0.9)} }

.dot {
  display: inline-block;
  width: 10px; height: 10px;
  background: #22c55e;
  border-radius: 50%;
  margin-right: 6px;
}

/* ===== COUNTDOWN ===== */
#countdownScreen { background: linear-gradient(135deg, #667eea22, #764ba222); }

.count-num {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(6rem, 25vw, 11rem);
  background: linear-gradient(135deg, var(--accent1), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: countIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes countIn {
  0% { transform: scale(2.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.go-txt {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(4rem, 18vw, 8rem);
  background: linear-gradient(135deg, #22c55e, #16a34a);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: goIn 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes goIn {
  0% { transform: scale(0) rotate(-15deg); opacity: 0; }
  100% { transform: scale(1) rotate(0); opacity: 1; }
}

/* ===== GAME SCREEN ===== */
#gameScreen {
  padding: 0;
  justify-content: flex-start;
  gap: 0;
}

.game-header {
  width: 100%;
  padding: 12px 16px;
  background: white;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.player-hud {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
  min-width: 80px;
}

.hud-label {
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #9ca3af;
}

.hud-name {
  font-family: 'Fredoka One', cursive;
  font-size: 0.95rem;
  color: var(--text);
  max-width: 90px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hud-score {
  font-family: 'Fredoka One', cursive;
  font-size: 1.3rem;
}

.score-left { color: var(--accent1); }
.score-right { color: var(--accent2); }

/* Arena */
.arena {
  width: 100%;
  padding: 10px 16px 0;
  position: relative;
  flex-shrink: 0;
}

/* Cat characters on rope */
.rope-scene {
  position: relative;
  width: 100%;
  height: 120px;
  display: flex;
  align-items: center;
}

.cat-left-wrap, .cat-right-wrap {
  position: absolute;
  bottom: 0;
  z-index: 3;
  transition: left 0.35s cubic-bezier(0.34,1.56,0.64,1), right 0.35s cubic-bezier(0.34,1.56,0.64,1);
}

.cat-left-wrap { left: 0; }
.cat-right-wrap { right: 0; }

.cat-left-wrap svg { width: 70px; height: 90px; }
.cat-right-wrap svg { width: 70px; height: 90px; transform: scaleX(-1); }

/* Pulling animation */
@keyframes tugLeft {
  0% { transform: translateX(0) rotate(0deg); }
  30% { transform: translateX(-12px) rotate(-8deg); }
  60% { transform: translateX(-6px) rotate(-4deg); }
  100% { transform: translateX(0) rotate(0deg); }
}
@keyframes tugRight {
  0% { transform: scaleX(-1) translateX(0) rotate(0deg); }
  30% { transform: scaleX(-1) translateX(-12px) rotate(-8deg); }
  60% { transform: scaleX(-1) translateX(-6px) rotate(-4deg); }
  100% { transform: scaleX(-1) translateX(0) rotate(0deg); }
}

.tug-left { animation: tugLeft 0.5s ease-out; }
.tug-right svg { animation: tugRight 0.5s ease-out; }

/* Rope track */
.rope-track-wrap {
  position: absolute;
  left: 60px;
  right: 60px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
}

.rope-track {
  width: 100%;
  height: 16px;
  background: #f3f4f6;
  border-radius: 8px;
  border: 2px solid #e5e7eb;
  overflow: hidden;
  position: relative;
}

.rope-fill {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    90deg,
    var(--rope-brown) 0px, var(--rope-brown) 8px,
    var(--rope-tan) 8px, var(--rope-tan) 14px
  );
  border-radius: 8px;
  transition: width 0.4s cubic-bezier(0.34,1.56,0.64,1);
}

.rope-center {
  position: absolute;
  left: 50%; top: -5px; bottom: -5px;
  width: 3px;
  background: #ef4444;
  transform: translateX(-50%);
  z-index: 4;
  border-radius: 2px;
}

.rope-center::after {
  content: '🔴';
  position: absolute;
  top: -10px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 10px;
}

.rope-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 2px;
  margin-top: 4px;
}
.rope-labels span {
  font-size: 0.65rem;
  font-weight: 800;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* Question area */
.question-area {
  width: 100%;
  padding: 12px 16px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  flex: 1;
}

/* Timer */
.timer-wrap {
  position: relative;
  width: 60px; height: 60px;
  flex-shrink: 0;
}
.timer-svg { transform: rotate(-90deg); }
.timer-bg { fill: none; stroke: #e5e7eb; stroke-width: 5; }
.timer-arc {
  fill: none;
  stroke: #22c55e;
  stroke-width: 5;
  stroke-linecap: round;
  stroke-dasharray: 157;
  stroke-dashoffset: 0;
  transition: stroke-dashoffset 0.1s linear, stroke 0.3s;
}
.timer-num {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Fredoka One', cursive;
  font-size: 1.2rem;
  color: var(--text);
}

/* Question */
.question-text {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(2.2rem, 9vw, 3.5rem);
  color: var(--text);
  text-align: center;
  line-height: 1;
}

/* Multiple choice */
.choices-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  width: 100%;
  max-width: 360px;
}

.choice-btn {
  padding: 18px 12px;
  border: 3px solid #e5e7eb;
  border-radius: 16px;
  background: white;
  font-family: 'Fredoka One', cursive;
  font-size: 1.6rem;
  color: var(--text);
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, transform 0.1s, box-shadow 0.15s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  text-align: center;
}
.choice-btn:active { transform: scale(0.95); }
.choice-btn:hover { border-color: var(--accent2); box-shadow: 0 4px 16px rgba(108,99,255,0.2); }

.choice-btn.correct {
  border-color: #22c55e;
  background: #dcfce7;
  color: #16a34a;
}
.choice-btn.wrong {
  border-color: #ef4444;
  background: #fee2e2;
  color: #dc2626;
}
.choice-btn.reveal-correct {
  border-color: #22c55e;
  background: #dcfce7;
  color: #16a34a;
}
.choice-btn:disabled { cursor: default; }

/* Feedback */
.feedback-popup {
  position: fixed;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  font-family: 'Fredoka One', cursive;
  font-size: 2rem;
  padding: 14px 28px;
  border-radius: 18px;
  z-index: 200;
  pointer-events: none;
  opacity: 0;
  transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), opacity 0.2s;
  white-space: nowrap;
}
.feedback-popup.show { transform: translate(-50%, -50%) scale(1); opacity: 1; }
.feedback-popup.correct { background: #dcfce7; color: #16a34a; border: 3px solid #22c55e; }
.feedback-popup.wrong { background: #fee2e2; color: #dc2626; border: 3px solid #ef4444; }
.feedback-popup.timeout { background: #fef3c7; color: #d97706; border: 3px solid #f59e0b; }

/* ===== RESULT SCREEN ===== */
#resultScreen { gap: 12px; }

.result-cats {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 20px;
  margin: 8px 0;
}

.result-cat-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.result-cat-wrap svg { width: 90px; height: 110px; }

.winner-cat { animation: jig 0.5s ease-in-out infinite alternate; }
@keyframes jig {
  0% { transform: translateY(0) rotate(-8deg) scale(1.05); }
  100% { transform: translateY(-14px) rotate(8deg) scale(1.1); }
}

.loser-cat { animation: sadDroop 1s ease-in-out infinite alternate; }
@keyframes sadDroop {
  0% { transform: translateY(0) rotate(-3deg); }
  100% { transform: translateY(4px) rotate(3deg); }
}

.result-label {
  font-family: 'Fredoka One', cursive;
  font-size: 0.9rem;
  text-align: center;
}

.winner-label { color: #16a34a; }
.loser-label { color: #9ca3af; }

.result-title {
  font-family: 'Fredoka One', cursive;
  font-size: clamp(2rem, 8vw, 3rem);
  text-align: center;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.result-scores {
  display: flex;
  gap: 12px;
  width: 100%;
  max-width: 360px;
}

.result-score-card {
  flex: 1;
  background: white;
  border-radius: 18px;
  padding: 16px 12px;
  text-align: center;
  box-shadow: 0 4px 16px var(--shadow);
}
.result-score-card .sc-name { font-weight: 800; font-size: 0.8rem; color: #6b7280; margin-bottom: 2px; }
.result-score-card .sc-val { font-family: 'Fredoka One', cursive; font-size: 2.2rem; }

/* Confetti */
.confetti-container { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
.cp {
  position: absolute;
  border-radius: 3px;
  animation: fall linear forwards;
}
@keyframes fall {
  0% { transform: translateY(-30px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(105vh) rotate(720deg); opacity: 0; }
}

/* Copy btn */
.copy-btn {
  width: 100%;
  padding: 10px;
  background: #f3f4f6;
  border: none;
  border-radius: 12px;
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  cursor: pointer;
  color: var(--text);
  margin-top: 6px;
  transition: background 0.2s;
}
.copy-btn:hover { background: #e5e7eb; }

.waiting-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-weight: 700;
  color: #6b7280;
  font-size: 0.9rem;
  margin: 8px 0;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 800;
}
.pill-wait { background: #fef3c7; color: #d97706; }
.pill-ready { background: #dcfce7; color: #16a34a; }

/* ===== SVG CATS ===== */
/* All cats are SVG inline components rendered via JS */
</style>
</head>
<body>

<div class="feedback-popup" id="feedbackPopup"></div>

<!-- ===== LOBBY ===== -->
<div class="screen active" id="lobbyScreen">
  <div class="title">Tug of WAR-X</div>
  <div class="subtitle">Math duels. Real cats. No mercy.</div>

  <div class="card">
    <div class="input-group">
      <label>Your Name</label>
      <input type="text" id="createName" placeholder="e.g. Nathaniel" maxlength="14">
    </div>
    <button class="btn btn-primary" onclick="createRoom()">Create Room →</button>
  </div>

  <div class="divider">— or join —</div>

  <div class="card">
    <div class="input-group">
      <label>Your Name</label>
      <input type="text" id="joinName" placeholder="e.g. Opponent" maxlength="14">
    </div>
    <div class="input-group">
      <label>Room Code</label>
      <input type="text" id="joinCode" placeholder="ABC123" maxlength="6" style="text-transform:uppercase;letter-spacing:0.18em;font-size:1.3rem;text-align:center;">
    </div>
    <button class="btn btn-secondary" onclick="joinRoom()">Join Room →</button>
  </div>
</div>

<!-- ===== BREED PICKER ===== -->
<div class="screen" id="pickerScreen">
  <div class="picker-title">Pick Your Fighter 🐾</div>
  <div class="picker-subtitle" id="pickerSubtitle">Choose your cat breed</div>

  <div class="breed-grid" id="breedGrid"></div>

  <div style="width:100%;max-width:400px;">
    <button class="btn btn-primary" id="readyBtn" onclick="confirmBreed()" disabled>I'm Ready! →</button>
  </div>

  <div id="waitingForOpp" style="display:none;margin-top:12px;" class="waiting-row">
    <span class="dot pulse"></span> Waiting for opponent to pick...
  </div>
</div>

<!-- ===== WAITING FOR PLAYER 2 ===== -->
<div class="screen" id="waitingScreen">
  <div class="title" style="font-size:1.8rem;">Waiting for Opponent</div>
  <div class="card" style="margin-top:16px;text-align:center;">
    <p style="font-weight:700;color:#9ca3af;font-size:0.85rem;margin-bottom:4px;">ROOM CODE</p>
    <div class="room-code" id="displayRoomCode">------</div>
    <button class="copy-btn" onclick="copyCode()">📋 Copy & Share Code</button>
    <div class="waiting-row" style="margin-top:14px;">
      <span class="dot pulse"></span> Waiting for player 2...
    </div>
    <p style="font-size:0.8rem;color:#9ca3af;font-weight:700;margin-top:6px;">Share the code with your friend!</p>
  </div>
</div>

<!-- ===== COUNTDOWN ===== -->
<div class="screen" id="countdownScreen">
  <div id="countDisplay" class="count-num">3</div>
</div>

<!-- ===== GAME ===== -->
<div class="screen" id="gameScreen">
  <div class="game-header">
    <div class="player-hud">
      <span class="hud-label">You</span>
      <span class="hud-name" id="myNameHud">-</span>
      <span class="hud-score score-left" id="myScoreHud">0</span>
    </div>
    <div style="font-family:'Fredoka One',cursive;color:#d1d5db;font-size:1.1rem;">VS</div>
    <div class="player-hud" style="align-items:flex-end;">
      <span class="hud-label">Them</span>
      <span class="hud-name" id="oppNameHud">-</span>
      <span class="hud-score score-right" id="oppScoreHud">0</span>
    </div>
  </div>

  <div class="arena">
    <div class="rope-scene">
      <!-- Left cat -->
      <div class="cat-left-wrap" id="catLeftWrap">
        <div id="catLeftSvg"></div>
      </div>
      <!-- Rope -->
      <div class="rope-track-wrap">
        <div class="rope-track">
          <div class="rope-fill" id="ropeFill" style="width:50%"></div>
          <div class="rope-center"></div>
        </div>
      </div>
      <!-- Right cat -->
      <div class="cat-right-wrap" id="catRightWrap">
        <div id="catRightSvg"></div>
      </div>
    </div>
    <div class="rope-labels">
      <span id="leftLabel">← Your side</span>
      <span id="rightLabel">Their side →</span>
