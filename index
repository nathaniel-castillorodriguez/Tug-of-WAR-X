const WIN_THRESHOLD = 15;

// ===== UTILS =====
function genCode() { return Math.random().toString(36).substring(2,8).toUpperCase(); }

function seededRand(seed) {
  const x = Math.sin(seed + 1) * 10000;
  return x - Math.floor(x);
}

function genQuestion(seed) {
  const a = Math.floor(seededRand(seed) * 9) + 1;
  const b = Math.floor(seededRand(seed + 100) * 9) + 1;
  return { a, b, answer: a * b };
}

function genChoices(correct) {
  const opts = new Set([correct]);
  const nearby = [
    correct + 1, correct - 1, correct + 2, correct - 2,
    correct + 9, correct - 9, correct + 11, correct - 11,
    correct + 10, correct - 10, correct * 2, Math.floor(correct * 1.5),
    correct + 7, correct - 7
  ].filter(v => v > 0 && v !== correct && v <= 81);

  // Shuffle nearby
  for (let i = nearby.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [nearby[i], nearby[j]] = [nearby[j], nearby[i]];
  }

  for (const v of nearby) {
    if (opts.size >= 4) break;
    opts.add(v);
  }

  // Fill if needed
  while (opts.size < 4) {
    const r = Math.floor(Math.random() * 80) + 1;
    opts.add(r);
  }

  const arr = [...opts];
  // Shuffle
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr.slice(0, 4);
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ===== BUILD BREED PICKER =====
function buildPicker() {
  const grid = document.getElementById('breedGrid');
  grid.innerHTML = '';
  BREEDS.forEach(breed => {
    const card = document.createElement('div');
    card.className = 'breed-card';
    card.id = `breed-${breed.id}`;
    card.innerHTML = `
      ${getCatSVG(breed.id, 'normal')}
      <div class="breed-name">${breed.name}</div>
    `;
    card.onclick = () => selectBreed(breed.id);
    grid.appendChild(card);
  });
}

function selectBreed(id) {
  document.querySelectorAll('.breed-card').forEach(c => c.classList.remove('selected'));
  document.getElementById(`breed-${id}`).classList.add('selected');
  myBreed = id;
  document.getElementById('readyBtn').disabled = false;
}

// ===== LOBBY =====
window.createRoom = async function() {
  const name = document.getElementById('createName').value.trim();
  if (!name) { alert('Enter your name!'); return; }
  myName = name;
  myRole = 'p1';
  roomCode = genCode();

  const state = {
    p1: { name, score: 0, breed: null, ready: false },
    p2: { name: '', score: 0, breed: null, ready: false },
    ropePosition: 50,
    status: 'waiting',
    questionSeed: Math.floor(Math.random() * 9999),
    currentQuestion: 0,
    createdAt: Date.now()
  };

  gameRef = ref(db, `games/${roomCode}`);
  await set(gameRef, state);
  document.getElementById('displayRoomCode').textContent = roomCode;
  showScreen('waitingScreen');
  listenForP2();
};

window.joinRoom = async function() {
  const name = document.getElementById('joinName').value.trim();
  const code = document.getElementById('joinCode').value.trim().toUpperCase();
  if (!name) { alert('Enter your name!'); return; }
  if (code.length !== 6) { alert('Enter a valid 6-digit code!'); return; }

  myName = name;
  myRole = 'p2';
  roomCode = code;
  gameRef = ref(db, `games/${roomCode}`);

  const snap = await get(gameRef);
  if (!snap.exists()) { alert('Room not found!'); return; }
  const data = snap.val();
  if (data.status !== 'waiting') { alert('Game already started!'); return; }

  oppName = data.p1.name;
  await update(gameRef, { 'p2/name': name, status: 'picking' });

  buildPicker();
  document.getElementById('pickerSubtitle').textContent = `You vs ${oppName} — Pick your fighter`;
  showScreen('pickerScreen');
  listenForGameState();
};

window.copyCode = function() {
  navigator.clipboard.writeText(roomCode).then(() => {
    const b = document.querySelector('.copy-btn');
    b.textContent = '✅ Copied!';
    setTimeout(() => b.textContent = '📋 Copy & Share Code', 2000);
  });
};

function listenForP2() {
  onValue(gameRef, snap => {
    const d = snap.val();
    if (!d) return;
    if (d.status === 'picking' && myRole === 'p1') {
      oppName = d.p2.name;
      off(gameRef);
      buildPicker();
      document.getElementById('pickerSubtitle').textContent = `You vs ${oppName} — Pick your fighter`;
      showScreen('pickerScreen');
      listenForGameState();
    }
  });
}

// ===== BREED CONFIRM =====
window.confirmBreed = async function() {
  if (!myBreed) return;
  document.getElementById('readyBtn').disabled = true;
  document.getElementById('waitingForOpp').style.display = 'flex';

  await update(gameRef, {
    [`${myRole}/breed`]: myBreed,
    [`${myRole}/ready`]: true,
  });

  // Check if both ready
  const snap = await get(gameRef);
  const d = snap.val();
  if (d.p1.ready && d.p2.ready) {
    await update(gameRef, { status: 'countdown' });
  }
};

// ===== GAME STATE LISTENER =====
function listenForGameState() {
  if (gameListener) off(gameRef);
  gameListener = onValue(gameRef, snap => {
    const d = snap.val();
    if (!d) return;

    if (d.status === 'countdown') {
      off(gameRef);
      oppBreed = myRole === 'p1' ? d.p2.breed : d.p1.breed;
      myBreed = myBreed || (myRole === 'p1' ? d.p1.breed : d.p2.breed);
      showScreen('countdownScreen');
      startCountdown(d);
      return;
    }

    if (d.status === 'playing') {
      const oppRole = myRole === 'p1' ? 'p2' : 'p1';
      oppScore = d[oppRole].score || 0;
      myScore = d[myRole].score || 0;
      ropePos = d.ropePosition || 50;
      updateScoreUI();
      updateRopeUI();
    }

    if (d.status === 'gameover') {
      clearInterval(timerInterval);
      showResult(d);
    }
  });
}

// ===== COUNTDOWN =====
function startCountdown(data) {
  let n = 3;
  const el = document.getElementById('countDisplay');

  function tick() {
    if (n > 0) {
      el.className = 'count-num';
      el.textContent = n;
      void el.offsetWidth;
      n--;
      setTimeout(tick, 900);
    } else {
      el.className = 'go-txt';
      el.textContent = 'GO!';
      setTimeout(async () => {
        await update(gameRef, { status: 'playing' });
        setupGameUI();
        showScreen('gameScreen');
        listenForGameState();
        startQuestion(data);
      }, 700);
    }
  }
  tick();
}

// ===== GAME UI SETUP =====
function setupGameUI() {
  document.getElementById('myNameHud').textContent = myName;
  document.getElementById('oppNameHud').textContent = oppName;

  // Left = p1 (cat), right = p2 (cat)
  const leftBreed = myRole === 'p1' ? myBreed : oppBreed;
  const rightBreed = myRole === 'p1' ? oppBreed : myBreed;

  document.getElementById('catLeftSvg').innerHTML = getCatSVG(leftBreed || 'tabby', 'normal');
  document.getElementById('catRightSvg').innerHTML = getCatSVG(rightBreed || 'siamese', 'normal');

  const leftName = myRole === 'p1' ? myName : oppName;
  const rightName = myRole === 'p1' ? oppName : myName;
  document.getElementById('leftLabel').textContent = `← ${leftName}`;
  document.getElementById('rightLabel').textContent = `${rightName} →`;
}

// ===== QUESTION =====
async function startQuestion(dataOverride) {
  answered = false;
  timeLeft = 5;

  const snap = dataOverride || (await get(gameRef)).val();
  const d = typeof snap.val === 'function' ? snap.val() : snap;

  const qIdx = d.currentQuestion || 0;
  const seed = d.questionSeed || 0;
  currentQuestion = genQuestion(seed + qIdx * 13);

  document.getElementById('questionText').textContent = `${currentQuestion.a} × ${currentQuestion.b} = ?`;

  choices = genChoices(currentQuestion.answer);
  correctIdx = choices.indexOf(currentQuestion.answer);

  const btns = document.querySelectorAll('.choice-btn');
  btns.forEach((b, i) => {
    b.textContent = choices[i];
    b.className = 'choice-btn';
    b.disabled = false;
  });

  updateTimer(5, 5);
  startTimer();
}

function startTimer() {
  clearInterval(timerInterval);
  const start = Date.now();

  timerInterval = setInterval(() => {
    timeLeft = Math.max(0, 5 - (Date.now() - start) / 1000);
    updateTimer(timeLeft, 5);
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      if (!answered) handleTimeout();
    }
  }, 50);
}

function updateTimer(cur, max) {
  const pct = cur / max;
  const circ = 157;
  document.getElementById('timerArc').style.strokeDashoffset = circ * (1 - pct);
  document.getElementById('timerNum').textContent = Math.ceil(cur);
  const arc = document.getElementById('timerArc');
  arc.style.stroke = pct > 0.5 ? '#22c55e' : pct > 0.25 ? '#f59e0b' : '#ef4444';
}

window.pickAnswer = function(idx) {
  if (answered) return;
  answered = true;
  clearInterval(timerInterval);

  const picked = choices[idx];
  const isCorrect = picked === currentQuestion.answer;
  const speedBonus = isCorrect ? Math.round((timeLeft / 5) * 2) : 0;
  const delta = isCorrect ? 1 + speedBonus : -2;

  const btns = document.querySelectorAll('.choice-btn');
  btns.forEach(b => b.disabled = true);
  btns[idx].className = `choice-btn ${isCorrect ? 'correct' : 'wrong'}`;
  if (!isCorrect) btns[correctIdx].className = 'choice-btn reveal-correct';

  showFeedback(
    isCorrect ? `+${1 + speedBonus}${speedBonus > 0 ? ' ⚡' : ' ✅'}` : `-2 ❌`,
    isCorrect ? 'correct' : 'wrong'
  );

  // Tug animation
  if (isCorrect) {
    if (myRole === 'p1') {
      document.getElementById('catLeftWrap').classList.add('tug-left');
      setTimeout(() => document.getElementById('catLeftWrap').classList.remove('tug-left'), 500);
    } else {
      document.getElementById('catRightWrap').classList.add('tug-right');
      setTimeout(() => document.getElementById('catRightWrap').classList.remove('tug-right'), 500);
    }
  }

  applyScore(delta);
};

function handleTimeout() {
  if (answered) return;
  answered = true;
  const btns = document.querySelectorAll('.choice-btn');
  btns.forEach(b => b.disabled = true);
  btns[correctIdx].className = 'choice-btn reveal-correct';
  showFeedback('Time! -2 ⏰', 'timeout');
  applyScore(-2);
}

async function applyScore(delta) {
  const snap = await get(gameRef);
  const d = snap.val();

  const newScore = (d[myRole].score || 0) + delta;
  const ropeDir = myRole === 'p1' ? -1 : 1;
  const newRope = Math.max(0, Math.min(100, (d.ropePosition || 50) + delta * ropeDir * 5));

  const updates = {};
  updates[`${myRole}/score`] = newScore;
  updates['ropePosition'] = newRope;

  let winner = null;
  if (newRope <= WIN_THRESHOLD) winner = 'p1';
  if (newRope >= 100 - WIN_THRESHOLD) winner = 'p2';

  if (winner) {
    updates['status'] = 'gameover';
    updates['winner'] = winner;
    await update(gameRef, updates);
  } else {
    updates['currentQuestion'] = (d.currentQuestion || 0) + 1;
    await update(gameRef, updates);
    setTimeout(() => startQuestion(), 1300);
  }
}

function showFeedback(text, type) {
  const el = document.getElementById('feedbackPopup');
  el.textContent = text;
  el.className = `feedback-popup ${type} show`;
  setTimeout(() => el.classList.remove('show'), 900);
}

function updateScoreUI() {
  document.getElementById('myScoreHud').textContent = myScore;
  document.getElementById('oppScoreHud').textContent = oppScore;
}

function updateRopeUI() {
  document.getElementById('ropeFill').style.width = ropePos + '%';
}

// ===== RESULT =====
function showResult(data) {
  clearInterval(timerInterval);
  const winner = data.winner;
  const iWon = winner === myRole;

  const p1Breed = data.p1.breed || 'tabby';
  const p2Breed = data.p2.breed || 'siamese';
  const myBreedFinal = myRole === 'p1' ? p1Breed : p2Breed;
  const oppBreedFinal = myRole === 'p1' ? p2Breed : p1Breed;

  const winnerBreed = winner === 'p1' ? p1Breed : p2Breed;
  const loserBreed = winner === 'p1' ? p2Breed : p1Breed;
  const winnerName = winner === 'p1' ? data.p1.name : data.p2.name;
  const loserName = winner === 'p1' ? data.p2.name : data.p1.name;

  // Left = winner, right = loser
  const leftEl = document.getElementById('resCatLeftSvg');
  const rightEl = document.getElementById('resCatRightSvg');
  const leftWrap = document.getElementById('resCatLeft');
  const rightWrap = document.getElementById('resCatRight');

  leftEl.innerHTML = getCatSVG(winnerBreed, 'happy');
  rightEl.innerHTML = getCatSVG(loserBreed, 'sad');
  rightEl.querySelector('svg').style.transform = 'scaleX(-1)';

  leftWrap.querySelector('.result-cat-wrap > div:first-child').className = 'winner-cat';
  rightWrap.querySelector('.result-cat-wrap > div:first-child').className = 'loser-cat';

  document.getElementById('resCatLeftLabel').innerHTML = `<span class="winner-label">🏆 ${winnerName}</span>`;
  document.getElementById('resCatRightLabel').innerHTML = `<span class="loser-label">😿 ${loserName}</span>`;

  document.getElementById('resSc1Name').textContent = data.p1.name;
  document.getElementById('resSc2Name').textContent = data.p2.name;
  document.getElementById('resSc1Val').textContent = data.p1.score || 0;
  document.getElementById('resSc2Val').textContent = data.p2.score || 0;

  if (iWon) {
    document.getElementById('resultTitle').textContent = '🎉 You Win!';
    document.getElementById('resultSub').textContent = `${oppName} got dragged over the line!`;
    launchConfetti();
  } else {
    document.getElementById('resultTitle').textContent = 'So Close! 😅';
    document.getElementById('resultTitle').style.background = 'linear-gradient(135deg,#6b7280,#374151)';
    document.getElementById('resultTitle').style.webkitBackgroundClip = 'text';
    document.getElementById('resultTitle').style.webkitTextFillColor = 'transparent';
    document.getElementById('resultSub').textContent = `${winnerName} pulled harder this time!`;
  }

  showScreen('resultScreen');
}

function launchConfetti() {
  const c = document.getElementById('confettiEl');
  c.innerHTML = '';
  const cols = ['#ff6b6b','#6c63ff','#ffd93d','#6bcb77','#4d96ff','#ff9ff3','#54a0ff'];
  for (let i = 0; i < 90; i++) {
    const p = document.createElement('div');
    p.className = 'cp';
    p.style.cssText = `
      left:${Math.random()*100}vw;
      width:${Math.random()*10+5}px;
      height:${Math.random()*10+5}px;
      background:${cols[Math.floor(Math.random()*cols.length)]};
      animation-duration:${Math.random()*2+2}s;
      animation-delay:${Math.random()*1.5}s;
      border-radius:${Math.random() > 0.5 ? '50%' : '3px'};
    `;
    c.appendChild(p);
  }
}

// ===== REMATCH =====
window.rematch = async function() {
  clearInterval(timerInterval);
  myScore = 0; oppScore = 0; ropePos = 50;

  // Reset game state, keep same players
  const snap = await get(gameRef);
  const d = snap.val();

  await update(gameRef, {
    'p1/score': 0,
    'p2/score': 0,
    'p1/breed': null,
    'p2/breed': null,
    'p1/ready': false,
    'p2/ready': false,
    ropePosition: 50,
    status: 'picking',
    questionSeed: Math.floor(Math.random() * 9999),
    currentQuestion: 0,
    winner: null,
  });

  myBreed = null;
  oppBreed = null;
  buildPicker();
  document.getElementById('readyBtn').disabled = true;
  document.getElementById('waitingForOpp').style.display = 'none';
  document.querySelectorAll('.breed-card').forEach(c => c.classList.remove('selected'));
  showScreen('pickerScreen');
  listenForGameState();
};

// ===== KEYBOARD =====
document.getElementById('joinCode').addEventListener('input', e => {
  e.target.value = e.target.value.toUpperCase();
});

// Init picker on load for display
buildPicker();
</script>
